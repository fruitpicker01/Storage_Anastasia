18\u041f. \u041f\u0440\u0435\u0434\u043d\u0430\u0437\u043d\u0430\u0447\u0435\u043d\u0430 \u0434\u043b\u044f \u043e\u043f\u043b\u0430\u0442\u044b \u043a\u043e\u043c\u0430\u043d\u0434\u0438\u0440\u043e\u0432\u043e\u0447\u043d\u044b\u0445, \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u0435\u043b\u044c\u0441\u043a\u0438\u0445 \u0440\u0430\u0441\u0445\u043e\u0434\u043e\u0432 \u0438 \u0434\u0440\u0443\u0433\u0438\u0445 \u043f\u043e\u043a\u0443\u043f\u043e\u043a \u0434\u043b\u044f \u0431\u0438\u0437\u043d\u0435\u0441\u0430. \u0418\u041f \u043c\u043e\u0433\u0443\u0442 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043a\u0430\u0440\u0442\u0443 \u0434\u043b\u044f \u043b\u0438\u0447\u043d\u044b\u0445 \u0446\u0435\u043b\u0435\u0439. \u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043a\u0430\u0440\u0442 \u043a \u043e\u0434\u043d\u043e\u043c\u0443 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u043e\u043c\u0443 \u0441\u0447\u0451\u0442\u0443 \u043d\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043e. \u041e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u0435 \u043e\u043d\u043b\u0430\u0439\u043d \u2014 \u043f\u043e \u0437\u0430\u044f\u0432\u043a\u0435 \u0432 \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442-\u0431\u0430\u043d\u043a\u0435 \u0421\u0431\u0435\u0440\u0411\u0438\u0437\u043d\u0435\u0441.\u00bb.\n\u041d\u0435 \u0438\u0437\u043c\u0435\u043d\u044f\u0439 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0421\u0431\u0435\u0440\u0411\u0438\u0437\u043d\u0435\u0441 \u041a\u0430\u0440\u0442\u0430\u00bb.\n\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430:\n\u00ab\u041e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435 \u2014 0 \u20bd \u0432 \u043f\u0435\u0440\u0432\u044b\u0439 \u0433\u043e\u0434. \u0415\u0441\u043b\u0438 \u0430\u043a\u0442\u0438\u0432\u043d\u043e \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u043a\u0430\u0440\u0442\u043e\u0439, \u043c\u043e\u0436\u043d\u043e \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u0441\u043a\u0438\u0434\u043a\u0443 \u0434\u043e 100% \u043d\u0430 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435 \u0432 \u043f\u043e\u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \u0433\u043e\u0434\u044b. \u041c\u043e\u0436\u043d\u043e \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432\u0441\u0435 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0438 \u0438 \u043f\u043e\u043b\u0443\u0447\u0430\u0442\u044c \u043e\u0442\u0447\u0451\u0442\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u043a\u0430\u0440\u0442\u0435 \u0432 \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442-\u0431\u0430\u043d\u043a\u0435 \u0421\u0431\u0435\u0440\u0411\u0438\u0437\u043d\u0435\u0441.\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u043b \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435 \u0442\u0440\u0435\u0445 \u0438 \u043d\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u0447\u0435\u0442\u044b\u0440\u0435\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0431\u0435\u0437 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439, \u0441\u0438\u043d\u043e\u043d\u0438\u043c\u043e\u0432 \u0438 \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a \u0441\u043b\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0421\u0431\u0435\u0440\u0411\u0438\u0437\u043d\u0435\u0441 \u041a\u0430\u0440\u0442\u0430\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0435\u0441\u0442\u044c \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0430\u044f \u043a\u043b\u044e\u0447\u0435\u0432\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f: \u00ab\u041a\u0430\u0440\u0442\u0430 \u0434\u043b\u044f \u0431\u0438\u0437\u043d\u0435\u0441\u0430 \u0441 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u044b\u043c \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435\u043c \u0432 \u043f\u0435\u0440\u0432\u044b\u0439 \u0433\u043e\u0434.\u00bb.", "sms_2": "\u041e\u0444\u043e\u0440\u043c\u0438\u0442\u0435 \u0421\u0431\u0435\u0440\u0411\u0438\u0437\u043d\u0435\u0441 \u041a\u0430\u0440\u0442\u0443 \u0434\u043b\u044f \u043b\u0451\u0433\u043a\u043e\u0433\u043e \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u0431\u0438\u0437\u043d\u0435\u0441-\u0440\u0430\u0441\u0445\u043e\u0434\u0430\u043c\u0438: \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e\u0435 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435 \u0432 \u043f\u0435\u0440\u0432\u044b\u0439 \u0433\u043e\u0434, \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u044c \u043f\u043e\u043b\u0443\u0447\u0430\u0442\u044c \u043e\u0442\u0447\u0451\u0442\u043d\u043e\u0441\u0442\u044c \u043e\u043d\u043b\u0430\u0439\u043d \u0438 \u043d\u0435\u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043d\u043e\u0435 \u0447\u0438\u0441\u043b\u043e \u043a\u0430\u0440\u0442 \u043a \u043e\u0434\u043d\u043e\u043c\u0443 \u0441\u0447\u0451\u0442\u0443.\n\n------\n\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0437\u043d\u0430\u043a\u043e\u0432: 187", "preferred_sms": "none"}