u0435\u0434\u0443\u044e\u0449\u0435\u0435 \u0421\u041c\u0421, \u043d\u043e \u043f\u0435\u0440\u0435\u0444\u0440\u0430\u0437\u0438\u0440\u0443\u0439 \u0435\u0433\u043e \u0438 \u0443\u0447\u0442\u0438 \u043d\u043e\u0432\u044b\u0435 \u0434\u0430\u0442\u044b:\n\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435, \u0434\u043e\u0431\u0430\u0432\u0438\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0432\u0430\u0448\u0435\u043c\u0443 \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445! \u041f\u0440\u043e\u0441\u0442\u043e \u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0433\u043e \u0432\u044b\u0440\u0443\u0447\u043a\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430 \u043f\u043e 44-\u0424\u0417 \u0434\u043e 31.12.25 \u2014 \u0430 \u043c\u044b \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0441\u0443\u043c\u043c\u044b \u043f\u043e\u0441\u0442\u0443\u043f\u043b\u0435\u043d\u0438\u0439. \u0423\u0437\u043d\u0430\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435 https://www.sberbank.com/ru/s_m_business/open-accounts/promo/goskontrakt \u041f\u0410\u041e \u0421\u0431\u0435\u0440\u0431\u0430\u043d\u043a\u00bb.\n\u041d\u0435 \u0438\u0437\u043c\u0435\u043d\u044f\u0439 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430:\n\u00ab\u043d\u0430\u0447\u0438\u0441\u043b\u044f\u0435\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u043b \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435 \u0442\u0440\u0435\u0445 \u0438 \u043d\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u0447\u0435\u0442\u044b\u0440\u0435\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0431\u0435\u0437 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439, \u0441\u0438\u043d\u043e\u043d\u0438\u043c\u043e\u0432 \u0438 \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a \u0441\u043b\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0435\u0441\u0442\u044c \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0430\u044f \u043a\u043b\u044e\u0447\u0435\u0432\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f: \u00ab\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0434\u043e 30.06.26 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445\u00bb.", "sms_1": "\u0414\u043e\u0445\u043e\u0434\u0438\u0442\u0435 \u0434\u043e \u043c\u0430\u043a\u0441\u0438\u043c\u0443\u043c\u0430 \u0441 \u0432\u044b\u0433\u043e\u0434\u043e\u0439! \u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0434\u043e 30. 06. 26 \u0438 \u043f\u043e\u043b\u0443\u0447\u0430\u0439\u0442\u0435 \u0434\u043e 100 000 \u0440 \u0441\u0432\u0435\u0440\u0445\u0443 \u043e\u0442 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 \u043f\u043e \u0433\u043e\u0441\u0437\u0430\u043a\u0430\u0437\u0430\u043c. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0448\u0430\u0433 \u043a \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u043c\u0443 \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u043a\u0443 \u0443\u0436\u0435 \u0441\u0435\u0433\u043e\u0434\u043d\u044f. \u041f\u043e\u0434\u0440\u043e\u0431\u043d\u043e\u0441\u0442\u0438 \u0437\u0434\u0435\u0441\u044c: https://www.\n\n------\n\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0437\u043d\u0430\u043a\u043e\u0432: 224", "model_2_name": "GPT-4o fine-tuned", "prompt_2": "\u041d\u0430\u043f\u0438\u0448\u0438 \u0442\u0440\u0438 \u0438\u043b\u0438 \u0447\u0435\u0442\u044b\u0440\u0435 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u041d\u0430\u043f\u0438\u0448\u0438 \u0440\u0435\u043a\u043b\u0430\u043c\u043d\u043e\u0435 SMS \u0434\u043b\u044f \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0433\u043e \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430:\n\u00ab\u0422\u0435\u0431\u0435 \u043d\u0443\u0436\u043d\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u0421\u041c\u0421 \u0434\u043b\u044f \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u0435\u0439 \u0438 \u0437\u0430\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043e\u0432\u0430\u0442\u044c \u0438\u0445 \u0430\u043a\u0446\u0438\u0435\u0439.\n\u0423\u0441\u043b\u043e\u0432\u0438\u044f \u0430\u043a\u0446\u0438\u0438: \u0434\u043e 30.06.26 \u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0433\u043e \u0432\u044b\u043f\u043b\u0430\u0442\u0443 \u043e\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430. \u041c\u044b \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0432\u0430\u0448\u0435\u0439 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 (\u043d\u043e \u043d\u0435 \u0431\u043e\u043b\u0435\u0435 100 \u0442\u044b\u0441. \u0440) \u0434\u043e 20.07.26.\n\n\u0412 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0440\u0435\u0444\u0435\u0440\u0435\u043d\u0441\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0435 \u0421\u041c\u0421, \u043d\u043e \u043f\u0435\u0440\u0435\u0444\u0440\u0430\u0437\u0438\u0440\u0443\u0439 \u0435\u0433\u043e \u0438 \u0443\u0447\u0442\u0438 \u043d\u043e\u0432\u044b\u0435 \u0434\u0430\u0442\u044b:\n\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435, \u0434\u043e\u0431\u0430\u0432\u0438\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0432\u0430\u0448\u0435\u043c\u0443 \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445! \u041f\u0440\u043e\u0441\u0442\u043e \u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0433\u043e \u0432\u044b\u0440\u0443\u0447\u043a\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430 \u043f\u043e 44-\u0424\u0417 \u0434\u043e 31.12.25 \u2014 \u0430 \u043c\u044b \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0441\u0443\u043c\u043c\u044b \u043f\u043e\u0441\u0442\u0443\u043f\u043b\u0435\u043d\u0438\u0439. \u0423\u0437\u043d\u0430\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435 https://www.sberbank.com/ru/s_m_business/open-accounts/promo/goskontrakt  \u041f\u0410\u041e \u0421\u0431\u0435\u0440\u0431\u0430\u043d\u043a\u00bb.\n\u041d\u0435 \u0438\u0437\u043c\u0435\u043d\u044f\u0439 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430:\n\u00ab\u043d\u0430\u0447\u0438\u0441\u043b\u044f\u0435\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u043b \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435 \u0442\u0440\u0435\u0445 \u0438 \u043d\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u0447\u0435\u0442\u044b\u0440\u0435\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0431\u0435\u0437 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439, \u0441\u0438\u043d\u043e\u043d\u0438\u043c\u043e\u0432 \u0438 \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a \u0441\u043b\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0435\u0441\u0442\u044c \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0430\u044f \u043a\u043b\u044e\u0447\u0435\u0432\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f: \u00ab\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0434\u043e 30.06.26 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445\u00bb.", "final_prompt_2": "\u041d\u0430\u043f\u0438\u0448\u0438 \u0442\u0440\u0438 \u0438\u043b\u0438 \u0447\u0435\u0442\u044b\u0440\u0435 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u041d\u0430\u043f\u0438\u0448\u0438 \u0440\u0435\u043a\u043b\u0430\u043c\u043d\u043e\u0435 SMS \u0434\u043b\u044f \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0433\u043e \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430:\n\u00ab\u0422\u0435\u0431\u0435 \u043d\u0443\u0436\u043d\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u0421\u041c\u0421 \u0434\u043b\u044f \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0442\u0435\u043b\u0435\u0439 \u0438 \u0437\u0430\u0438\u043d\u0442\u0435\u0440\u0435\u0441\u043e\u0432\u0430\u0442\u044c \u0438\u0445 \u0430\u043a\u0446\u0438\u0435\u0439.\n\u0423\u0441\u043b\u043e\u0432\u0438\u044f \u0430\u043a\u0446\u0438\u0438: \u0434\u043e 30.06.26 \u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0433\u043e \u0432\u044b\u043f\u043b\u0430\u0442\u0443 \u043e\u0442 \u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u0438\u044f \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430. \u041c\u044b \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0432\u0430\u0448\u0435\u0439 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 (\u043d\u043e \u043d\u0435 \u0431\u043e\u043b\u0435\u0435 100 \u0442\u044b\u0441. \u0440) \u0434\u043e 20.07.26. \u0412 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435 \u0440\u0435\u0444\u0435\u0440\u0435\u043d\u0441\u0430 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0439 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0435 \u0421\u041c\u0421, \u043d\u043e \u043f\u0435\u0440\u0435\u0444\u0440\u0430\u0437\u0438\u0440\u0443\u0439 \u0435\u0433\u043e \u0438 \u0443\u0447\u0442\u0438 \u043d\u043e\u0432\u044b\u0435 \u0434\u0430\u0442\u044b:\n\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435, \u0434\u043e\u0431\u0430\u0432\u0438\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0432\u0430\u0448\u0435\u043c\u0443 \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445! \u041f\u0440\u043e\u0441\u0442\u043e \u043e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u043d\u0430 \u043d\u0435\u0433\u043e \u0432\u044b\u0440\u0443\u0447\u043a\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430 \u043f\u043e 44-\u0424\u0417 \u0434\u043e 31.12.25 \u2014 \u0430 \u043c\u044b \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0441\u0443\u043c\u043c\u044b \u043f\u043e\u0441\u0442\u0443\u043f\u043b\u0435\u043d\u0438\u0439. \u0423\u0437\u043d\u0430\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u0435 https://www.sberbank.com/ru/s_m_business/open-accounts/promo/goskontrakt \u041f\u0410\u041e \u0421\u0431\u0435\u0440\u0431\u0430\u043d\u043a\u00bb.\n\u041d\u0435 \u0438\u0437\u043c\u0435\u043d\u044f\u0439 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430:\n\u00ab\u043d\u0430\u0447\u0438\u0441\u043b\u044f\u0435\u043c \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043e\u0442 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442\u0430\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u043d\u0430\u043f\u0438\u0441\u0430\u043b \u043d\u0435 \u043c\u0435\u043d\u044c\u0448\u0435 \u0442\u0440\u0435\u0445 \u0438 \u043d\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u0447\u0435\u0442\u044b\u0440\u0435\u0445 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u0438\u0439 \u0441\u0443\u043c\u043c\u0430\u0440\u043d\u043e\u0439 \u0434\u043b\u0438\u043d\u043e\u0439 \u043e\u0442 160 \u0434\u043e 250 \u0437\u043d\u0430\u043a\u043e\u0432 \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043f\u0440\u043e\u0431\u0435\u043b\u043e\u0432.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0431\u0435\u0437 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439, \u0441\u0438\u043d\u043e\u043d\u0438\u043c\u043e\u0432 \u0438 \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a \u0441\u043b\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u043d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u0430: \u00ab\u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442\u00bb.\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0432 SMS \u0435\u0441\u0442\u044c \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0430\u044f \u043a\u043b\u044e\u0447\u0435\u0432\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f: \u00ab\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0434\u043e 30.06.26 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0434\u043e 100 \u0442\u044b\u0441. \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445\u00bb.", "sms_2": "\u041e\u0442\u043a\u0440\u043e\u0439\u0442\u0435 \u0440\u0430\u0441\u0447\u0451\u0442\u043d\u044b\u0439 \u0441\u0447\u0451\u0442 \u0432 \u0421\u0431\u0435\u0440\u0435 \u0434\u043e 30. 06. 26 \u0438 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0434\u043e 100 000 \u0440 \u043a \u0434\u043e\u0445\u043e\u0434\u0443 \u043d\u0430 \u0442\u0435\u043d\u0434\u0435\u0440\u0430\u0445! \u0412\u0441\u0451 \u043f\u0440\u043e\u0441\u0442\u043e: \u043d\u0430\u0447\u0438\u0441\u043b\u0438\u043c 1% \u043e\u0442 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 \u043f\u0440\u0438 \u043f\u043e\u0441\u0442\u0443\u043f\u043b\u0435\u043d\u0438\u0438 \u0432\u044b\u043f\u043b\u0430\u0442\u044b \u0437\u0430 \u0433\u043e\u0441\u043a\u043e\u043d\u0442\u0440\u0430\u043a\u0442 \u043d\u0430 \u0432\u0430\u0448 \u0441\u0447\u0451\u0442.\n\n------\n\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0437\u043d\u0430\u043a\u043e\u0432: 178", "preferred_sms": "none"}